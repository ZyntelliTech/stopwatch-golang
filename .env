APP_NAME=Stopwatch_Go_Backend
DEBUG=true
PORT=8000
BLE_NAME_PREFIX=Stopwatch
MOCK_BLE=false
WIFI_SERVICE_UUID=59462f12-9543-9999-12c8-58b459a2712d
WIFI_CONFIG_CHAR_UUID=33333333-2222-2222-1111-111100000000
WIFI_STATUS_CHAR_UUID=33333333-2222-2222-1111-111100000000

# MQTT (broker connection happens at server startup)
MQTT_ENABLED=true
MQTT_BROKER_HOST=swimbrain.local
MQTT_BROKER_PORT=8883
MQTT_PUBLISH_TOPIC=stopwatch/{device_id}/cmd
MQTT_SUBSCRIBE_TOPIC=stopwatch/+/data
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CONNECT_TIMEOUT_SEC=5
MQTT_TLS_CA_FILE=/etc/mosquitto/certs/ca.crt
MQTT_TLS_ALLOW_LEGACY_CN=true
